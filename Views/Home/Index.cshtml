function buildSearchForm() {
    return `
    <div>
        <p style="font-size:14px;color:#666;margin-bottom:14px;">
            Nhập số điện thoại bạn đã dùng khi đặt bàn hoặc đặt món.
        </p>
        <div style="display:flex;gap:10px;margin-bottom:16px;">
            <input type="tel" id="searchPhone" placeholder="Nhập số điện thoại..."
                style="flex:1;padding:11px 14px;border:1.5px solid #ddd;border-radius:8px;font-size:14px;outline:none"
                onkeydown="if(event.key==='Enter') findOrder()"
                onfocus="this.style.borderColor='#e44d26'" onblur="this.style.borderColor='#ddd'">
            <button onclick="findOrder()"
                style="padding:11px 22px;background:#e44d26;color:white;border:none;
                       border-radius:8px;cursor:pointer;font-weight:700;font-size:14px;">
                <i class="fas fa-search"></i> Tìm
            </button>
        </div>
        <div id="searchResult" style="min-height:60px;">
            <p style="text-align:center;color:#ccc;font-style:italic;padding:20px 0;">
                Nhập SĐT và nhấn Tìm để tra cứu
            </p>
        </div>
    </div>`;
}

async function findOrder() {
    const phone = document.getElementById('searchPhone')?.value?.trim();
    if (!phone) { showToast('Vui lòng nhập số điện thoại!', true); return; }

    const container = document.getElementById('searchResult');
    container.innerHTML = '<p style="text-align:center;padding:20px;color:#aaa"><i class="fas fa-spinner fa-spin"></i> Đang tìm kiếm...</p>';

    try {
        const res = await fetch(`/Home/Search?phone=${encodeURIComponent(phone)}`).then(r => r.json());

        if (!res.success || (res.orders.length === 0 && res.bookings.length === 0)) {
            container.innerHTML = `<div style="text-align:center;padding:20px;color:#dc3545;">
                <i class="fas fa-search" style="font-size:28px;opacity:0.4;display:block;margin-bottom:8px"></i>
                Không tìm thấy thông tin cho SĐT <strong>${phone}</strong>
            </div>`;
            return;
        }

        let html = `<p style="font-weight:700;margin-bottom:10px;font-size:13px;">
            Kết quả cho SĐT: <span style="color:#e44d26">${phone}</span></p>`;

        const statusColor = { pending:'#ff9800', confirmed:'#1976d2', cooking:'#2e7d32',
                              cooked:'#0288d1', shipping:'#7b1fa2', done:'#388e3c', cancelled:'#d32f2f' };

        res.orders.forEach(o => {
            const color = statusColor[o.status] || '#666';
            html += `<div style="background:#f0f7ff;padding:12px;border-radius:8px;margin-bottom:8px;border-left:4px solid #1976d2;">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
                    <strong style="color:#1976d2"><i class="fas fa-utensils"></i> Đơn hàng #${o.orderCode}</strong>
                    <span style="background:${color};color:white;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700">${o.statusText}</span>
                </div>
                <p style="font-size:13px;margin-top:6px;color:#555">
                    ${o.items.map(i => `${i.menuItemName} ×${i.quantity}`).join(', ')}
                </p>
                <p style="font-size:12px;color:#888;margin-top:3px">
                    Tổng: <strong>${o.totalPrice.toLocaleString('vi')}đ</strong> |
                    Nhận: ${new Date(o.pickupTime).toLocaleString('vi')}
                </p>
            </div>`;
        });

        res.bookings.forEach(b => {
            const color = statusColor[b.status] || '#666';
            html += `<div style="background:#f0fff4;padding:12px;border-radius:8px;margin-bottom:8px;border-left:4px solid #388e3c;">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
                    <strong style="color:#388e3c"><i class="fas fa-chair"></i> Đặt bàn #${b.bookingCode}</strong>
                    <span style="background:${color};color:white;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700">${b.statusText}</span>
                </div>
                <p style="font-size:13px;margin-top:6px;color:#555">
                    ${b.bookingDate} | ${b.timeSlotName} | ${b.guestCount} người
                </p>
                ${b.note ? `<p style="font-size:12px;color:#888;margin-top:3px">Ghi chú: ${b.note}</p>` : ''}
            </div>`;
        });

        container.innerHTML = html;
    } catch(e) {
        container.innerHTML = '<p style="color:red;text-align:center">Lỗi kết nối, vui lòng thử lại!</p>';
    }
}

